# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/firmsync

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Authentication
SESSION_SECRET=your_session_secret_here_min_32_characters
JWT_SECRET=your_jwt_secret_here_min_32_characters
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_EXPIRES=7d

# Environment
NODE_ENV=development

# Security
CORS_ORIGIN=http://localhost:5000

# Session Configuration
SESSION_MAX_AGE=86400000

# Rate Limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
ENABLE_AUDIT_LOGGING=true

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Email Configuration (Optional)
SENDGRID_API_KEY=your_sendgrid_api_key_here
FROM_EMAIL=noreply@yourfirm.com

# Third-party Integrations (Optional)
DROPBOX_APP_KEY=your_dropbox_app_key
DROPBOX_APP_SECRET=your_dropbox_app_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret