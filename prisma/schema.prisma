// This is your Prisma schema file
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Basic firm information
model Firm {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("active") // active, suspended, setup
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Billing and subscription info
  subscriptionTier String  @default("basic")
  billingEmail    String?
  trialEndsAt     DateTime?

  // Contact information
  contactName  String?
  contactEmail String?
  contactPhone String?

  // Related records
  agents             Agent[]
  agentPrompts       AgentPrompt[]
  agentWorkflows     AgentWorkflow[]
  integrationConfigs IntegrationConfig[]
  documentTemplates  DocumentTemplate[]

  @@index([status])
  @@index([subscriptionTier])
}

// Agent definitions
model Agent {
  id          String   @id @default(cuid())
  firmId      String
  name        String
  description String?
  type        String   // researcher, analyst, coordinator, etc.
  status      String   @default("active")
  model       String   @default("gpt-4") // AI model to use
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Configuration
  systemPrompt    String  // Base personality and instructions
  temperature     Float   @default(0.7)
  maxTokens       Int     @default(2000)
  topP           Float   @default(1.0)
  frequencyPenalty Float  @default(0.0)
  presencePenalty  Float  @default(0.0)

  // Feature flags and capabilities
  capabilities Json    @default("{}")
  metadata     Json?

  // Relationships
  firm          Firm           @relation(fields: [firmId], references: [id], onDelete: Cascade)
  prompts       AgentPrompt[]
  workflows     AgentWorkflow[]
  assignments   AgentAssignment[]

  @@unique([firmId, name])
  @@index([firmId])
  @@index([type])
  @@index([status])
}

// Customizable prompts for different contexts
model AgentPrompt {
  id          String   @id @default(cuid())
  firmId      String
  agentId     String
  name        String
  description String?
  prompt      String   // The actual prompt template
  context     String?  // Additional context or instructions
  category    String   // e.g., research, analysis, review
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  firm    Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([firmId, agentId, name])
  @@index([firmId])
  @@index([agentId])
  @@index([category])
}

// Workflow definitions for agent routing
model AgentWorkflow {
  id          String   @id @default(cuid())
  firmId      String
  agentId     String
  name        String
  description String?
  trigger     String   // Event that starts the workflow
  rules       Json     // Routing and decision rules
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  firm    Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([firmId, name])
  @@index([firmId])
  @@index([agentId])
  @@index([trigger])
}

// Third-party service integrations
model IntegrationConfig {
  id          String   @id @default(cuid())
  firmId      String
  type        String   // e.g., docusign, clio, etc.
  name        String
  config      Json     // Connection details, encrypted if sensitive
  status      String   @default("active")
  lastSync    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  firm    Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([firmId, type, name])
  @@index([firmId])
  @@index([type])
  @@index([status])
}

// Document templates
model DocumentTemplate {
  id          String   @id @default(cuid())
  firmId      String
  name        String
  description String?
  type        String   // e.g., contract, letter, form
  category    String?  // Optional categorization
  content     String   // Template content with variables
  variables   Json     // Schema of required variables
  format      String   @default("markdown") // markdown, docx, pdf
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  firm    Firm    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  agentAssignment AgentAssignment?

  @@unique([firmId, name, version])
  @@index([firmId])
  @@index([type])
  @@index([category])
}

// Agent assignments to document types
model AgentAssignment {
  documentType   DocumentTemplate @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
  documentTypeId String          @id
  agent         Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId       String
  workflow      Json            @default("{}")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([agentId])
}
